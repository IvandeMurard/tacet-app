# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# --- Mapbox (V1 / SearchBar geocoding fallback) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# --- Bruitparif RUMEUR API (V2, server-side only) ---
# Required for real-time noise data. Obtain access via TAC-28.
# Leave empty to use mock data in development.
BRUITPARIF_API_KEY=

# Optional: override the Bruitparif RUMEUR endpoint (defaults to official API URL).
# BRUITPARIF_API_URL=https://api.bruitparif.fr/rumeur/v1/data

# --- Anthropic (Epic 6 / Zone Enrichment Agent) ---
# Server-side only. Used by /api/enrich route handler.
ANTHROPIC_API_KEY=

# --- Contact form (Story 5.4) ---
# Resend API key — obtain at resend.com. Required for POST /api/contact.
RESEND_API_KEY=re_your_api_key_here
# Recipient address for all contact/B2B form submissions.
CONTACT_TO_EMAIL=contact@tacet.vercel.app
# Sender shown to recipients. Must be a verified Resend domain.
# Use "onboarding@resend.dev" on the free plan for testing.
CONTACT_FROM_EMAIL=Tacet <onboarding@resend.dev>

# --- Feature flags ---
# Set to "true" to enable the RUMEUR real-time layer in the UI.
NEXT_PUBLIC_ENABLE_RUMEUR=false
# Set to "true" to enable the Zone Enrichment Agent (AI summaries in IrisPopup).
NEXT_PUBLIC_ENABLE_ENRICHMENT=false
