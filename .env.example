# Tacet — Environment example
# NE COMMITEZ JAMAIS les fichiers .env ou .env.local !

# ------------------------------------------------------------------------------
# Application Next.js (dossier tacet/)
# ------------------------------------------------------------------------------
# L'app lit les variables depuis tacet/.env.local
# Créez tacet/.env.local et ajoutez :

# Mapbox — token public (commence par pk.), exposé côté client
# Obtenir un token : https://account.mapbox.com/ > Access tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here
